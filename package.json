{
  "name": "blizzard-tracker",
  "version": "2.6.0",
  "description": "Team Blizzard live race tracker for the RBC Brooklyn Half. Svelte + TypeScript rewrite.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview --host",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tsconfig/svelte": "^5.0.4",
    "@types/leaflet": "^1.9.12",
    "svelte": "^4.2.19",
    "svelte-check": "^4.0.4",
    "tslib": "^2.7.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "chart.js": "^4.4.5",
    "chartjs-plugin-zoom": "^2.2.0",
    "hammerjs": "^2.0.8",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0"
  }
}
